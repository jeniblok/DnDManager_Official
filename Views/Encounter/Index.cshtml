@model IEnumerable<DnDManager.Models.Encounter>

@{
    ViewData["Title"] = "Encounters";
}

<h2>Encounters</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Encounter</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Outcome</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.Name</td>
            <td>@item.Outcome</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
